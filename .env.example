# SentinelScope environment configuration
# Copy this file to `.env` and edit values as needed.

# Network interface the Express server binds to.
#
# Default: 127.0.0.1 (loopback only). Anything else exposes the
# unauthenticated scanner UI to other hosts on that interface, which is
# almost always wrong. Override only when you are deliberately running the
# tool inside a trusted environment (firewall, VPN, reverse proxy with auth).
#
# Examples:
#   HOST=127.0.0.1   # loopback only — default, recommended
#   HOST=0.0.0.0     # all interfaces — DANGEROUS without external auth
HOST=127.0.0.1

# Port the Express server binds to. Default: 5000.
PORT=5000

# Allow scans of localhost / RFC1918 / link-local / IPv6 ULA targets.
# Default: false. Set to "true" only on lab networks where you have
# explicit authorization to scan internal hosts. Per-scan opt-in via the
# "Allow private/LAN target" checkbox is preferred over a global override.
# ALLOW_PRIVATE_TARGETS=false

# Optional NVD API key. Without it, NVD enforces a stricter rate limit (5 reqs / 30s).
# Request a key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
