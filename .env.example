# SentinelScope environment configuration
# Copy this file to `.env` and edit values as needed.

# Port the Express server binds to. Default: 5000.
PORT=5000

# Optional NVD API key. Without it, NVD enforces a stricter rate limit (5 reqs / 30s).
# Request a key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
